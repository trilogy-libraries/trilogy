#!/usr/bin/env ruby
# frozen_string_literal: true

# Benchmark: DateTime casting performance in Trilogy
#
# Measures the cost of parsing MySQL datetime strings into Ruby Time/Date objects.
# Run BEFORE and AFTER the byte-arithmetic parser change to compare.
#
# Usage: ./script/benchmark_datetime

require "rubygems" if !defined?(Gem)

# Skip bundler — mysql2 may not be installed
$LOAD_PATH.unshift(File.expand_path("../../lib", __dir__))

require "benchmark/ips"
require "trilogy"
require "date"

DEFAULT_HOST = ENV["MYSQL_HOST"] || "127.0.0.1"
DEFAULT_PORT = (port = ENV["MYSQL_PORT"].to_i) && port != 0 ? port : 3306
DEFAULT_USER = ENV["MYSQL_USER"] || "root"
DEFAULT_PASS = ENV["MYSQL_PASS"]

connect_options = {
  host:     DEFAULT_HOST,
  port:     DEFAULT_PORT,
  username: DEFAULT_USER,
  password: DEFAULT_PASS,
}

client = Trilogy.new(connect_options)
client.query("CREATE DATABASE IF NOT EXISTS trilogy_bench")
client.change_db("trilogy_bench")

# Create a table with various datetime column types
client.query("DROP TABLE IF EXISTS datetime_bench")
client.query(<<-SQL)
  CREATE TABLE datetime_bench (
    id INT AUTO_INCREMENT PRIMARY KEY,
    dt DATETIME NOT NULL,
    dt3 DATETIME(3) NOT NULL,
    dt6 DATETIME(6) NOT NULL,
    d DATE NOT NULL,
    t TIME NOT NULL,
    t3 TIME(3) NOT NULL,
    ts TIMESTAMP NOT NULL DEFAULT CURRENT_TIMESTAMP
  )
SQL

# Insert test rows — use a bulk approach for 10,000 rows
puts "Inserting 10,000 test rows..."
client.query("INSERT INTO datetime_bench (dt, dt3, dt6, d, t, t3) VALUES ('2024-06-15 14:30:45', '2024-06-15 14:30:45.123', '2024-06-15 14:30:45.123456', '2024-06-15', '14:30:45', '14:30:45.123')")
# Double repeatedly: 1 -> 2 -> 4 -> ... -> 8192 -> 10000
13.times { client.query("INSERT INTO datetime_bench (dt, dt3, dt6, d, t, t3) SELECT dt, dt3, dt6, d, t, t3 FROM datetime_bench") }
# Trim to exactly 10000
count = client.query("SELECT COUNT(*) FROM datetime_bench").to_a[0][0]
client.query("DELETE FROM datetime_bench ORDER BY id DESC LIMIT #{count - 10000}") if count > 10000

row_count = client.query("SELECT COUNT(*) FROM datetime_bench").to_a[0][0]

puts "=" * 70
puts "Trilogy DateTime Casting Benchmark"
puts "=" * 70
puts "Ruby: #{RUBY_VERSION} | Trilogy: #{Trilogy::VERSION}"
puts "Rows in table: #{row_count}"
puts

# --- Benchmark 1: DATETIME (no fractional seconds) ---
puts "-" * 70
puts "1. SELECT DATETIME column (100 rows)"
puts "-" * 70

Benchmark.ips do |x|
  x.warmup = 1
  x.time = 5

  x.report("DATETIME with casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_CAST
    client.query("SELECT dt FROM datetime_bench").to_a
  end

  x.report("DATETIME no casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_NONE
    client.query("SELECT dt FROM datetime_bench").to_a
  end

  x.compare!
end

# --- Benchmark 2: DATETIME(3) with milliseconds ---
puts "-" * 70
puts "2. SELECT DATETIME(3) column (100 rows, millisecond precision)"
puts "-" * 70

Benchmark.ips do |x|
  x.warmup = 1
  x.time = 5

  x.report("DATETIME(3) with casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_CAST
    client.query("SELECT dt3 FROM datetime_bench").to_a
  end

  x.report("DATETIME(3) no casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_NONE
    client.query("SELECT dt3 FROM datetime_bench").to_a
  end

  x.compare!
end

# --- Benchmark 3: DATETIME(6) with microseconds ---
puts "-" * 70
puts "3. SELECT DATETIME(6) column (100 rows, microsecond precision)"
puts "-" * 70

Benchmark.ips do |x|
  x.warmup = 1
  x.time = 5

  x.report("DATETIME(6) with casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_CAST
    client.query("SELECT dt6 FROM datetime_bench").to_a
  end

  x.report("DATETIME(6) no casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_NONE
    client.query("SELECT dt6 FROM datetime_bench").to_a
  end

  x.compare!
end

# --- Benchmark 4: DATE column ---
puts "-" * 70
puts "4. SELECT DATE column (100 rows)"
puts "-" * 70

Benchmark.ips do |x|
  x.warmup = 1
  x.time = 5

  x.report("DATE with casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_CAST
    client.query("SELECT d FROM datetime_bench").to_a
  end

  x.report("DATE no casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_NONE
    client.query("SELECT d FROM datetime_bench").to_a
  end

  x.compare!
end

# --- Benchmark 5: TIME column ---
puts "-" * 70
puts "5. SELECT TIME column (100 rows)"
puts "-" * 70

Benchmark.ips do |x|
  x.warmup = 1
  x.time = 5

  x.report("TIME with casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_CAST
    client.query("SELECT t FROM datetime_bench").to_a
  end

  x.report("TIME no casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_NONE
    client.query("SELECT t FROM datetime_bench").to_a
  end

  x.compare!
end

# --- Benchmark 6: TIME(3) with precision ---
puts "-" * 70
puts "6. SELECT TIME(3) column (100 rows)"
puts "-" * 70

Benchmark.ips do |x|
  x.warmup = 1
  x.time = 5

  x.report("TIME(3) with casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_CAST
    client.query("SELECT t3 FROM datetime_bench").to_a
  end

  x.report("TIME(3) no casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_NONE
    client.query("SELECT t3 FROM datetime_bench").to_a
  end

  x.compare!
end

# --- Benchmark 7: All datetime columns together ---
puts "-" * 70
puts "7. SELECT all datetime columns (100 rows x 7 columns)"
puts "-" * 70

Benchmark.ips do |x|
  x.warmup = 1
  x.time = 5

  x.report("All columns with casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_CAST
    client.query("SELECT dt, dt3, dt6, d, t, t3, ts FROM datetime_bench").to_a
  end

  x.report("All columns no casting") do
    client.query_flags = Trilogy::QUERY_FLAGS_NONE
    client.query("SELECT dt, dt3, dt6, d, t, t3, ts FROM datetime_bench").to_a
  end

  x.compare!
end

# --- Benchmark 8: Pure Ruby Time construction (floor reference) ---
puts "-" * 70
puts "8. Pure Ruby Time.utc construction (floor reference, 10000 iterations)"
puts "-" * 70

Benchmark.ips do |x|
  x.warmup = 1
  x.time = 5

  x.report("Time.utc (no usec)") do |times|
    i = 0
    while i < times
      10000.times { Time.utc(2024, 6, 15, 14, 30, 45) }
      i += 1
    end
  end

  x.report("Time.utc (with usec)") do |times|
    i = 0
    while i < times
      10000.times { Time.utc(2024, 6, 15, 14, 30, 45, 123456) }
      i += 1
    end
  end

  x.report("Date.new") do |times|
    i = 0
    while i < times
      10000.times { Date.new(2024, 6, 15) }
      i += 1
    end
  end

  x.compare!
end

# Cleanup
client.query("DROP TABLE IF EXISTS datetime_bench")
client.close

# --- Benchmark 9: CPU-time micro-benchmark (isolates parsing from I/O) ---
puts "-" * 70
puts "9. CPU-time casting overhead (per-row incremental cost)"
puts "-" * 70

# Reconnect and setup for micro-benchmark
client = Trilogy.new(connect_options)
client.query("CREATE DATABASE IF NOT EXISTS trilogy_bench")
client.change_db("trilogy_bench")
client.query("DROP TABLE IF EXISTS datetime_micro")
client.query("CREATE TABLE datetime_micro (dt DATETIME(6) NOT NULL)")
client.query("INSERT INTO datetime_micro (dt) VALUES ('2024-06-15 14:30:45.123456')")
9.times { client.query("INSERT INTO datetime_micro (dt) SELECT dt FROM datetime_micro") }
row_count = client.query("SELECT COUNT(*) FROM datetime_micro").to_a[0][0]
puts "  Rows: #{row_count}"

iterations = 50

# Measure with casting (CPU time only)
client.query_flags = Trilogy::QUERY_FLAGS_CAST
GC.disable
cpu_start = Process.clock_gettime(Process::CLOCK_PROCESS_CPUTIME_ID)
iterations.times { client.query("SELECT dt FROM datetime_micro").to_a }
cpu_cast = Process.clock_gettime(Process::CLOCK_PROCESS_CPUTIME_ID) - cpu_start
GC.enable
GC.start

# Measure without casting (CPU time only)
client.query_flags = Trilogy::QUERY_FLAGS_NONE
GC.disable
cpu_start = Process.clock_gettime(Process::CLOCK_PROCESS_CPUTIME_ID)
iterations.times { client.query("SELECT dt FROM datetime_micro").to_a }
cpu_nocast = Process.clock_gettime(Process::CLOCK_PROCESS_CPUTIME_ID) - cpu_start
GC.enable
GC.start

total_rows = iterations * row_count
cast_per_row_ns = ((cpu_cast - cpu_nocast) / total_rows * 1_000_000_000).round(1)

puts "  CPU time with casting:    #{'%.4f' % cpu_cast}s (#{iterations} iterations)"
puts "  CPU time without casting: #{'%.4f' % cpu_nocast}s (#{iterations} iterations)"
puts "  Casting overhead:         #{'%.4f' % (cpu_cast - cpu_nocast)}s total"
puts "  Per-row casting cost:     #{cast_per_row_ns} ns/row"
puts "  Total rows processed:     #{total_rows}"

client.query("DROP TABLE IF EXISTS datetime_micro")
client.close

puts
puts "=" * 70
puts "Benchmark complete."
puts "=" * 70
